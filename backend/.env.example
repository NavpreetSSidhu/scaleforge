PORT=8080
DATABASE_URL=postgres://scaleforge:scaleforge@localhost:5432/scaleforge?sslmode=disable
CORS_ORIGIN=http://localhost:5173
GIN_MODE=debug
DEV_USER_ID=00000000-0000-0000-0000-000000000001
# Secret used to sign JWTs (HS256). Use a long random value in production.
JWT_SECRET=dev-insecure-secret-change-me
# AI assistant (optional). Set a Groq API key (free tier: https://console.groq.com)
# to enable the architecture assistant. Leave empty to disable the feature.
GROQ_API_KEY=
# Override the assistant's LLM model (defaults to llama-3.3-70b-versatile).
ASSIST_MODEL=
